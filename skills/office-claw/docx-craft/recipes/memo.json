{
  "name": "memo",
  "label": "备忘录",
  "fonts": {
    "body": {
      "ascii": "Arial",
      "eastAsia": "微软雅黑",
      "hAnsi": "Arial",
      "size": 22
    },
    "heading": {
      "ascii": "Arial",
      "eastAsia": "微软雅黑",
      "hAnsi": "Arial"
    }
  },
  "headings": [
    { "level": 0, "size": 40, "bold": true, "spacing": { "before": 0, "after": 240 } },
    { "level": 1, "size": 32, "bold": true, "spacing": { "before": 360, "after": 180 } },
    { "level": 2, "size": 26, "bold": true, "spacing": { "before": 240, "after": 120 } },
    { "level": 3, "size": 24, "bold": true, "spacing": { "before": 200, "after": 100 } },
    { "level": 4, "size": 22, "bold": true, "spacing": { "before": 160, "after": 80 } }
  ],
  "page": {
    "width": 12240,
    "height": 15840,
    "margin": {
      "top": 1440,
      "bottom": 1440,
      "left": 1440,
      "right": 1440
    },
    "preset": "letter",
    "marginPreset": "standard"
  },
  "lineSpacing": 276,
  "sections": ["body"],
  "header": {
    "text": "",
    "align": "left"
  },
  "footer": {
    "type": "page_number",
    "align": "center"
  },
  "extendedStyles": {
    "toc": {
      "levels": [
        { "level": 1, "indent": 0, "bold": true },
        { "level": 2, "indent": 240, "bold": false }
      ]
    },
    "list": {
      "bullet": { "indent": 720, "hanging": 360 },
      "number": { "indent": 720, "hanging": 360 }
    },
    "quote": {
      "normal": {
        "indent": { "left": 720, "right": 720, "firstLine": 0 },
        "spacing": { "before": 240, "after": 240 },
        "italics": true
      }
    },
    "table": {
      "borders": {
        "style": "single",
        "size": 4,
        "color": "auto"
      },
      "headerRow": {
        "fill": "F2F2F2",
        "bold": true
      }
    },
    "comment": {
      "textSize": 20,
      "referenceSize": 16
    }
  }
}
